<body>
    <div class="container">
        <h1>New Zealand Public Holidays 2026</h1>
        <p>Download the <a href="new-zealand-public-holidays-2026.ics">ICS file</a> to add these holidays to your calendar.</p>
        <ul class="holiday-list">
            <li><strong>01-01</strong>: New Year's Day</li>
            <li><strong>01-02</strong>: Day after New Year</li>
            <li><strong>02-06</strong>: Waitangi Day</li>
            <li><strong>04-10</strong>: Good Friday</li>
            <li><strong>04-13</strong>: Easter Monday</li>
            <li><strong>04-25</strong>: Anzac Day</li>
            <li><strong>06-01</strong>: Queen's Birthday</li>
            <li><strong>10-26</strong>: Labour Day</li>
            <li><strong>12-25</strong>: Christmas Day</li>
            <li><strong>12-26</strong>: Boxing Day</li>
        </ul>
    </div>
